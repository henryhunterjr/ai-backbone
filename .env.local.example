# Supabase — get these from supabase.com → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# OpenAI — for generating embeddings (~$0.02 per million tokens)
OPENAI_API_KEY=sk-...your-openai-key

# Backbone auth — make up any strong secret (e.g. a UUID)
BACKBONE_API_KEY=your-secret-api-key-here
